# Environment Configuration - Copy to .env and update values

# Server Configuration
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/

# Database Configuration (H2 - Development)
SPRING_DATASOURCE_URL=jdbc:h2:mem:saas_pm
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.h2.Driver
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=password
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.H2Dialect
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Database Configuration (PostgreSQL - Production)
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/saas_pm
# SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=postgres
# SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQL10Dialect

# Spring Profile
SPRING_PROFILES_ACTIVE=default

# JPA Configuration
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true

# JWT Configuration
APP_JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-at-least-32-chars
APP_JWT_EXPIRATION_MS=86400000

# AI Configuration
APP_AI_CLAUDE_API_KEY=
APP_AI_USE_MOCK=true

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_SAAS_PM=DEBUG

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Multi-Tenancy
MULTI_TENANT_ENABLED=true

# File Upload
UPLOAD_DIR=/tmp/uploads
MAX_UPLOAD_SIZE=10485760
